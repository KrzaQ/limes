# limes config — copy to ~/.config/limes/config.toml and edit.
#
# Per-machine and hand-written: it names absolute paths that differ across machines,
# so don't sync it (same idea as ~/.gitconfig). Not installed by anything — reference only.
#
# limes also reads ~/.config/limes/config.d/*.toml, merged with this file (this one wins
# on a collision). config.d/ is for whole files owned by a tool or installer — e.g. a
# dotfiles repo shipping its own shell rc entries — so they need no merge surgery here.

[mounts]
# The path is the key, so a path can't be listed twice. `~` and `$VAR` are expanded.
# Every path must exist, or `lim` fails loud (like a bad --ro/--rw) — unless `optional`.

# Mount your dotfiles repo read-only, so shell startup can reach repo-relative files
# (zsh plugins, sourced helpers) that the individual config-file mounts don't cover.
"~/code/misc/dotfiles" = "ro"

# "ro" is shorthand for { mode = "ro" }. The long form adds optional per-path options:
# "~/scratch" = { mode = "rw" }

# `link = "parent"` — for a symlinked dotfile. docker flattens a symlink when it mounts
# it, so config that finds siblings relative to its own resolved path (zsh locating its
# plugins via ~/.zshrc) breaks inside. This instead recreates the symlink in the sandbox
# and mounts its target's parent dir, so self-locating config resolves as it does here.
# "~/.zshrc" = { mode = "ro", link = "parent" }

# `optional = true` — skip silently if the path is absent, for files that exist on only
# some of your machines.
# "~/.zshrc.local" = { mode = "ro", optional = true }

# "hide" — the path exists inside the sandbox but is empty, and the host's contents are
# unreachable. It's for punching a hole in a mount that is otherwise too broad: mount
# ~/.config ro so 35 tools work, then take back the dirs that hold credentials. Directories
# only (hiding a file is an error); the empty dir is writable but nothing in it reaches the
# host; and hiding a path that isn't there is a silent no-op, so this is safe to sync.
# "~/.config/gh"      = "hide"
# "~/.config/secrets" = "hide"
#
# It is a blocklist, and blocklists rot — next month's tool drops a token somewhere new and
# nothing warns you. Use it as a bridge, not as a guarantee that the sandbox holds no keys.

# Config mounts override the built-in defaults but lose to CLI flags: `--rw <path>` still
# wins for a single run, and `--no-config` ignores this file entirely.

# Standing on/off switches for the credential and socket forwards. All default to on, and
# each no-ops silently when the thing it forwards isn't there — so you only need a line
# here to turn something off. Same precedence as mounts: CLI beats config, in both
# directions, so a `false` here is still escapable with `--gpg` for one run.
# [forward]
# ssh    = true    # SSH agent socket
# gpg    = false   # GPG extra (restricted) agent socket
# rosa   = true    # sub rosa secret broker: socket + client binary
# docker = false   # the limes docker socket (also drops DOCKER_HOST)
